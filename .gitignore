*~

# Data and logs (LOCAL runtime files - DO NOT commit)
data/logs/
data/metadata.db           # Local SQLite database (auto-generated from template.db)
data/uploads/*.csv          # User-uploaded CSV files
data/uploads/*.xlsx         # User-uploaded Excel files
data/uploads/**/*.xlsx      # User-uploaded Excel files (recursive)
data/processed/**/*.xlsx    # User-processed Excel files (runtime output)
data/rejected/              # Runtime rejected-artefact files
data/master_files/          # Runtime DuckDB master file artifacts
data/module_*/              # Runtime module-isolated storage

# Exceptions to ensure DuckDB master files are shipped with the template
!data/module_*/master_files/
!data/module_*/master_files/**/*.duckdb

# Deploy bundle (COMMITTED to git - used by startup_event on fresh deploys)
# template.db              <- keep this tracked (DO NOT add to ignore)
# data/template_master_dbs/ <- keep this tracked (DO NOT add to ignore)

# Debug and test files
debug_*.py
test_*.py
test_debug.py
temp_debug.py
db_inspection.txt

# OS
.DS_Store
Thumbs.db

# Environment
.env
.env.local

# Node modules (if applicable)
node_modules/

data/*
!data/module_*/
data/module_*/*
data/module_*/master_files/*
data/module_*/master_files/folder_*/*

# Track ONLY the safe scrubbed templates, never the live ones
!data/template_master_dbs/
!data/template_master_dbs/**